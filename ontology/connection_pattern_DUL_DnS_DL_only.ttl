###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PrecedenceClaim
:PrecedenceClaim rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity> ,
                                 <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation> ,
                                 [ rdf:type owl:Class ;
                                   owl:unionOf ( <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Event>
                                                 <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation>
                                               )
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> ;
                                   owl:someValuesFrom <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Description>
                                 ] .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PrimaryJoint
:PrimaryJoint rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( :AtomicConnection
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :hasEndpoint ;
                                                           owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                           owl:onClass :StructuralPart
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
              rdfs:subClassOf :AtomicConnection ,
                              :ConnectionSituation ,
                              [ owl:intersectionOf ( :AtomicConnection
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty :hasEndpoint ;
                                                       owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                       owl:onClass :StructuralPart
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] .


