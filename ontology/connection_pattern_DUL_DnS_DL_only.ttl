                                                                             owl:onProperty <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isClassifiedBy> ;
                                                                             owl:allValuesFrom <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Role>
                                                                           ] .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#definesRole
<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#definesRole> rdfs:subPropertyOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#associatedWith> ,
                                                                                       <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#usesConcept> ;
