###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/laterJoint
:laterJoint rdf:type owl:ObjectProperty ;
            rdfs:domain <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity> ,
                        <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation> ,
                        :PrecedenceClaim ,
                        [ rdf:type owl:Class ;
                          owl:unionOf ( <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Event>
                                        <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation>
                                      )
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> ;
                          owl:someValuesFrom <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Description>
                        ] ;
            rdfs:range <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity> ,
                       <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation> ,
                       :AtomicConnection ,
                       :ConnectionSituation ,
                       :PrimaryJoint ,
                       [ owl:intersectionOf ( :AtomicConnection
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty :hasEndpoint ;
                                                owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                owl:onClass :StructuralPart
                                              ]
                                            ) ;
                         rdf:type owl:Class
                       ] ,
                       [ rdf:type owl:Class ;
                         owl:unionOf ( <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Event>
                                       <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation>
                                     )
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> ;
                         owl:someValuesFrom <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Description>
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasEndpoint ;
                         owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                         owl:onClass :StructuralPart
                       ] .


