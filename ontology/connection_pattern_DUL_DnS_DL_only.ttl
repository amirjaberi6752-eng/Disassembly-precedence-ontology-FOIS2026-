###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/ClosurePJ
:ClosurePJ rdf:type owl:Class ;
           rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity> ,
                           <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation> ,
                           :AtomicConnection ,
                           :ConnectionSituation ,
                           :PrimaryJoint ,
                           [ owl:intersectionOf ( :AtomicConnection
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :hasEndpoint ;
                                                    owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                    owl:onClass :StructuralPart
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ,
                           [ owl:intersectionOf ( :ConnectionSituation
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :hasEndpoint ;
                                                    owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                    owl:onClass :AssemblyArtifact
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> ;
                             owl:someValuesFrom <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Description>
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasEndpoint ;
                             owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                             owl:onClass :AssemblyArtifact
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasEndpoint ;
                             owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                             owl:onClass :StructuralPart
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasFitRegime ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :FitRegime
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasInterfaceGeometry ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :InterfaceGeometry
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasKinematicFunction ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :KinematicFunction
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasRetentionMethod ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :RetentionMethod
                           ] .


