                                                                                                                   ]
                                                                                                                 ) ;
                                                                                              rdf:type owl:Class
                                                                                            ] ,
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSettingFor> ;
