                                                                                             owl:onProperty <http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/hasEndpoint> ;
                                                                                             owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                                                             owl:onClass <http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/AssemblyArtifact>
                                                                                           ] ,
                                                                                           [ rdf:type owl:Restriction ;
