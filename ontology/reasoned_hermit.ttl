                                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                                           owl:onProperty <http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/hasEndpoint> ;
                                                                                                                           owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                                                                                           owl:onClass <http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/StructuralPart>
                                                                                                                         ]
                                                                                                                       ) ;
                                                                                                    rdf:type owl:Class
                                                                                                  ] ;
                                                                              rdfs:subClassOf <http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/AtomicConnection> ,
                                                                                              [ owl:intersectionOf ( <http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/AtomicConnection>
                                                                                                                     [ rdf:type owl:Restriction ;
                                                                                                                       owl:onProperty <http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/hasEndpoint> ;
                                                                                                                       owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                                                                                       owl:onClass <http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/StructuralPart>
                                                                                                                     ]
                                                                                                                   ) ;
                                                                                                rdf:type owl:Class
                                                                                              ] .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/ReferenceSupportPart
<http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/ReferenceSupportPart> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf <http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/StructuralPart> ,
                                                                                                      [ rdf:type owl:Class ;
