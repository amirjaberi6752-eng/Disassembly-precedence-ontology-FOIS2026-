###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Parthood
<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Parthood> rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeIndexedRelation> ,
                                                                                 [ owl:intersectionOf ( <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation>
                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                          owl:onProperty <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSettingFor> ;
                                                                                                          owl:someValuesFrom <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeInterval>
                                                                                                        ]
                                                                                                      ) ;
                                                                                   rdf:type owl:Class
                                                                                 ] ,
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSettingFor> ;
                                                                                   owl:someValuesFrom <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity>
                                                                                 ] ,
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSettingFor> ;
                                                                                   owl:someValuesFrom <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeInterval>
                                                                                 ] ,
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> ;
                                                                                   owl:someValuesFrom <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Description>
                                                                                 ] .


