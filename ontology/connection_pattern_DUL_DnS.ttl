@prefix : <http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix connection-pattern: <http://www.semanticweb.org/ajaberi/fois2026/connection-pattern#> .
@prefix connection_pattern: <http://www.semanticweb.org/ajaberi/fois2026/connection-pattern#> .
@base <http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/> .

<http://www.semanticweb.org/ajaberi/fois2026/connection-pattern> rdf:type owl:Ontology ;
                                                                  owl:imports <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl> .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasPostcondition
<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasPostcondition> rdfs:domain <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity> ;
                                                                         rdfs:range <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity> .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#includesPart
<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#includesPart> rdfs:domain <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation> ;
                                                                     rdfs:range <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity> .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#includesWhole
<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#includesWhole> rdfs:domain <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation> ;
                                                                      rdfs:range <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity> .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#realizesSelfInformation
<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#realizesSelfInformation> rdfs:domain <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#InformationRealization> ;
                                                                                rdfs:range <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity> .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/closureReachableViaSeatPair
:closureReachableViaSeatPair rdf:type owl:ObjectProperty ;
                             rdfs:domain :PrimaryJoint ;
                             rdfs:range :PrimaryJoint .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/defaultPrecedes
:defaultPrecedes rdf:type owl:ObjectProperty ;
                 rdfs:domain :PrimaryJoint ;
                 rdfs:range :PrimaryJoint .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/earlierJoint
:earlierJoint rdf:type owl:ObjectProperty ;
              rdfs:domain :PrecedenceClaim ;
              rdfs:range :PrimaryJoint .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/hasEndpoint
:hasEndpoint rdf:type owl:ObjectProperty ;
             rdfs:domain :ConnectionSituation ;
             rdfs:range :AssemblyArtifact .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/hasFitRegime
:hasFitRegime rdf:type owl:ObjectProperty ;
              rdfs:domain :ConnectionSituation ;
              rdfs:range :FitRegime .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/hasInterfaceGeometry
:hasInterfaceGeometry rdf:type owl:ObjectProperty ;
                      rdfs:domain :ConnectionSituation ;
                      rdfs:range :InterfaceGeometry .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/hasKinematicFunction
:hasKinematicFunction rdf:type owl:ObjectProperty ;
                      rdfs:domain :ConnectionSituation ;
                      rdfs:range :KinematicFunction .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/hasRetentionMethod
:hasRetentionMethod rdf:type owl:ObjectProperty ;
                    rdfs:domain :ConnectionSituation ;
                    rdfs:range :RetentionMethod .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/laterJoint
:laterJoint rdf:type owl:ObjectProperty ;
            rdfs:domain :PrecedenceClaim ;
            rdfs:range :PrimaryJoint .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/sharesCouplingPartPair
:sharesCouplingPartPair rdf:type owl:ObjectProperty ,
                                 owl:SymmetricProperty ;
                        rdfs:domain :PrimaryJoint ;
                        rdfs:range :PrimaryJoint .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/sharesEndpointPair
:sharesEndpointPair rdf:type owl:ObjectProperty ,
                             owl:SymmetricProperty ;
                    rdfs:domain :PrimaryJoint ;
                    rdfs:range :PrimaryJoint .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/sharesPowerEndpointPair
:sharesPowerEndpointPair rdf:type owl:ObjectProperty ,
                                  owl:SymmetricProperty ;
                         rdfs:domain :PrimaryJoint ;
                         rdfs:range :PrimaryJoint .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/sharesSupportEndpointPair
:sharesSupportEndpointPair rdf:type owl:ObjectProperty ,
                                    owl:SymmetricProperty ;
                           rdfs:domain :PrimaryJoint ;
                           rdfs:range :PrimaryJoint .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/commitmentScore
:commitmentScore rdf:type owl:DatatypeProperty ;
                 rdfs:domain :PrimaryJoint ,
                             [ owl:intersectionOf ( :ConnectionSituation
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :hasEndpoint ;
                                                      owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                      owl:onClass :AssemblyArtifact
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasEndpoint ;
                               owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                               owl:onClass :AssemblyArtifact
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasEndpoint ;
                               owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                               owl:onClass :StructuralPart
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasFitRegime ;
                               owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onClass :FitRegime
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasInterfaceGeometry ;
                               owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onClass :InterfaceGeometry
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasKinematicFunction ;
                               owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onClass :KinematicFunction
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasRetentionMethod ;
                               owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onClass :RetentionMethod
                             ] ;
                 rdfs:range xsd:integer .


#################################################################
#    Classes
#################################################################

###  http://www.co-ode.org/ontologies/ont.owl#:PrecedenceDescription
<http://www.co-ode.org/ontologies/ont.owl#:PrecedenceDescription> rdf:type owl:Class ;
                                                                  rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Description> .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#DesignedArtifact
<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#DesignedArtifact> rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isDescribedBy> ;
                                                                                           owl:someValuesFrom <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Plan>
                                                                                         ] .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#WorkflowExecution
<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#WorkflowExecution> rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PlanExecution> .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/AssemblyArtifact
:AssemblyArtifact rdf:type owl:Class ;
                  rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalObject> .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/AtomicConnection
:AtomicConnection rdf:type owl:Class ;
                  rdfs:subClassOf :ConnectionSituation .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Bolt
:Bolt rdf:type owl:Class ;
      rdfs:subClassOf :FastenerRetainer .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/ClosureAccessPart
:ClosureAccessPart rdf:type owl:Class ;
                   rdfs:subClassOf :StructuralPart .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/ClosurePJ
:ClosurePJ rdf:type owl:Class ;
           rdfs:subClassOf :PrimaryJoint ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasEndpoint ;
                             owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                             owl:onClass :AssemblyArtifact
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasFitRegime ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :FitRegime
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasInterfaceGeometry ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :InterfaceGeometry
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasKinematicFunction ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :KinematicFunction
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasRetentionMethod ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :RetentionMethod
                           ] .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/ConnectionSituation
:ConnectionSituation rdf:type owl:Class ;
                     rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation> .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/CouplerSeatPJ
:CouplerSeatPJ rdf:type owl:Class ;
               rdfs:subClassOf :PrimaryJoint ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasEndpoint ;
                                 owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                 owl:onClass :AssemblyArtifact
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasFitRegime ;
                                 owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :FitRegime
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasInterfaceGeometry ;
                                 owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :InterfaceGeometry
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasKinematicFunction ;
                                 owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :KinematicFunction
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasRetentionMethod ;
                                 owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :RetentionMethod
                               ] .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/CouplingPart
:CouplingPart rdf:type owl:Class ;
              rdfs:subClassOf :StructuralPart .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/DefaultMacroPrecedence
:DefaultMacroPrecedence rdf:type owl:Class ;
                        rdfs:subClassOf :PrecedenceClaim .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/DefaultMicroPrecedence
:DefaultMicroPrecedence rdf:type owl:Class ;
                        rdfs:subClassOf :PrecedenceClaim .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Descriptor
:Descriptor rdf:type owl:Class .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/FastenerRetainer
:FastenerRetainer rdf:type owl:Class ;
                  rdfs:subClassOf :Part ;
                  owl:disjointWith :StructuralPart .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/FitRegime
:FitRegime rdf:type owl:Class ;
           rdfs:subClassOf :Descriptor .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/InterfaceGeometry
:InterfaceGeometry rdf:type owl:Class ;
                   rdfs:subClassOf :Descriptor .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Key
:Key rdf:type owl:Class ;
     rdfs:subClassOf :FastenerRetainer .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/KinematicFunction
:KinematicFunction rdf:type owl:Class ;
                   rdfs:subClassOf :Descriptor .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/LockLikePJ
:LockLikePJ rdf:type owl:Class ;
            rdfs:subClassOf :PrimaryJoint ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasEndpoint ;
                              owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                              owl:onClass :AssemblyArtifact
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasFitRegime ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass :FitRegime
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasInterfaceGeometry ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass :InterfaceGeometry
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasKinematicFunction ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass :KinematicFunction
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasRetentionMethod ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass :RetentionMethod
                            ] ;
            owl:disjointWith :NonLockLikePJ .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/MobilityRealizationPart
:MobilityRealizationPart rdf:type owl:Class ;
                         rdfs:subClassOf :StructuralPart .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/MotionRelevantPJ
:MotionRelevantPJ rdf:type owl:Class ;
                  rdfs:subClassOf :PrimaryJoint ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :hasEndpoint ;
                                    owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                    owl:onClass :AssemblyArtifact
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :hasFitRegime ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass :FitRegime
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :hasInterfaceGeometry ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass :InterfaceGeometry
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :hasKinematicFunction ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass :KinematicFunction
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :hasRetentionMethod ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass :RetentionMethod
                                  ] .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/MountedPowerElementPJ
:MountedPowerElementPJ rdf:type owl:Class ;
                       rdfs:subClassOf :PrimaryJoint ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :hasEndpoint ;
                                         owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                         owl:onClass :AssemblyArtifact
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :hasFitRegime ;
                                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass :FitRegime
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :hasInterfaceGeometry ;
                                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass :InterfaceGeometry
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :hasKinematicFunction ;
                                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass :KinematicFunction
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :hasRetentionMethod ;
                                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass :RetentionMethod
                                       ] .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/MustPrecedence
:MustPrecedence rdf:type owl:Class ;
                rdfs:subClassOf :PrecedenceClaim .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/NonLockLikePJ
:NonLockLikePJ rdf:type owl:Class ;
               rdfs:subClassOf :PrimaryJoint ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasEndpoint ;
                                 owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                 owl:onClass :AssemblyArtifact
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasFitRegime ;
                                 owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :FitRegime
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasInterfaceGeometry ;
                                 owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :InterfaceGeometry
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasKinematicFunction ;
                                 owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :KinematicFunction
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasRetentionMethod ;
                                 owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :RetentionMethod
                               ] .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Nut
:Nut rdf:type owl:Class ;
     rdfs:subClassOf :FastenerRetainer .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Part
:Part rdf:type owl:Class ;
      rdfs:subClassOf :AssemblyArtifact .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Pin
:Pin rdf:type owl:Class ;
     rdfs:subClassOf :FastenerRetainer .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PowerTransferPart
:PowerTransferPart rdf:type owl:Class ;
                   rdfs:subClassOf :StructuralPart .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PrecedenceClaim
:PrecedenceClaim rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation> .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PrimaryJoint
:PrimaryJoint rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( :AtomicConnection
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :hasEndpoint ;
                                                           owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                           owl:onClass :StructuralPart
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/ReferenceSupportPart
:ReferenceSupportPart rdf:type owl:Class ;
                      rdfs:subClassOf :StructuralPart .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/RetentionMethod
:RetentionMethod rdf:type owl:Class ;
                 rdfs:subClassOf :Descriptor .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Sealing
:Sealing rdf:type owl:Class ;
         rdfs:subClassOf :FastenerRetainer .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/SnapRing
:SnapRing rdf:type owl:Class ;
          rdfs:subClassOf :FastenerRetainer .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/StructuralPart
:StructuralPart rdf:type owl:Class ;
                rdfs:subClassOf :Part .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/WasherShim
:WasherShim rdf:type owl:Class ;
            rdfs:subClassOf :FastenerRetainer .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/A1
:A1 rdf:type owl:NamedIndividual ,
             <http://www.co-ode.org/ontologies/ont.owl#:PrecedenceDescription> ;
    <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSatisfiedBy> :dmp_PJ3_PJ10 ,
                                                                          :dmp_PJ3_PJ11 ,
                                                                          :dmp_PJ3_PJ12 ,
                                                                          :dmp_PJ3_PJ9 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/A2
:A2 rdf:type owl:NamedIndividual ,
             <http://www.co-ode.org/ontologies/ont.owl#:PrecedenceDescription> ;
    <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSatisfiedBy> :dmp_PJ3_PJ4 ,
                                                                          :dmp_PJ3_PJ5 ,
                                                                          :dmp_PJ3_PJ7 ,
                                                                          :dmp_PJ3_PJ8 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/B1
:B1 rdf:type owl:NamedIndividual ,
             <http://www.co-ode.org/ontologies/ont.owl#:PrecedenceDescription> ;
    <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSatisfiedBy> :dmp_PJ4_PJ9 ,
                                                                          :dmp_PJ5_PJ11 ,
                                                                          :dmp_PJ7_PJ10 ,
                                                                          :dmp_PJ8_PJ12 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Bearing1
:Bearing1 rdf:type owl:NamedIndividual ,
                   :CouplingPart .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Bearing2
:Bearing2 rdf:type owl:NamedIndividual ,
                   :CouplingPart .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Bearing3
:Bearing3 rdf:type owl:NamedIndividual ,
                   :CouplingPart .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Bearing4
:Bearing4 rdf:type owl:NamedIndividual ,
                   :CouplingPart .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/BoltedFastening
:BoltedFastening rdf:type owl:NamedIndividual ,
                          :RetentionMethod .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Clearance
:Clearance rdf:type owl:NamedIndividual ,
                    :FitRegime .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Cylindrical
:Cylindrical rdf:type owl:NamedIndividual ,
                      :InterfaceGeometry .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/CylindricalMotion
:CylindricalMotion rdf:type owl:NamedIndividual ,
                            :KinematicFunction .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/F1
:F1 rdf:type owl:NamedIndividual ,
             <http://www.co-ode.org/ontologies/ont.owl#:PrecedenceDescription> ;
    <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSatisfiedBy> :dmp_PJ7_PJ6 ,
                                                                          :dmp_PJ8_PJ6 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Fixed
:Fixed rdf:type owl:NamedIndividual ,
                :KinematicFunction .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Gear
:Gear rdf:type owl:NamedIndividual ,
               :PowerTransferPart .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/GearboxCase
:GearboxCase rdf:type owl:NamedIndividual ,
                      :ReferenceSupportPart .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/GearboxCover
:GearboxCover rdf:type owl:NamedIndividual ,
                       :ClosureAccessPart ;
              :hasEndpoint :Bearing1 ,
                           :Pinion .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/InputShaft
:InputShaft rdf:type owl:NamedIndividual ,
                     :PowerTransferPart ;
            :hasEndpoint :Bearing1 ,
                         :GearboxCase .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Interference
:Interference rdf:type owl:NamedIndividual ,
                       :FitRegime .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/KeyRetention
:KeyRetention rdf:type owl:NamedIndividual ,
                       :RetentionMethod .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PJ1
:PJ1 rdf:type owl:NamedIndividual ,
              :LockLikePJ ;
     :defaultPrecedes :PJ10 ,
                      :PJ2 ,
                      :PJ9 ;
     :hasEndpoint :GearboxCase ,
                  :Pump ;
     :hasInterfaceGeometry :Planar ;
     :hasRetentionMethod :BoltedFastening ;
     :sharesEndpointPair :PJ10 ,
                         :PJ2 ,
                         :PJ3 ,
                         :PJ9 ;
     :sharesPowerEndpointPair :PJ2 ;
     :sharesSupportEndpointPair :PJ10 ,
                                :PJ3 ,
                                :PJ9 ;
     :commitmentScore "2"^^xsd:int .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PJ10
:PJ10 rdf:type owl:NamedIndividual ,
               :CouplerSeatPJ ,
               :NonLockLikePJ ;
      :hasEndpoint :Bearing3 ,
                   :GearboxCase ;
      :hasInterfaceGeometry :Cylindrical ;
      :hasKinematicFunction :Fixed ;
      :hasRetentionMethod :PressFitFriction ;
      :sharesCouplingPartPair :PJ7 ;
      :sharesEndpointPair :PJ1 ,
                          :PJ3 ,
                          :PJ7 ,
                          :PJ9 ;
      :sharesSupportEndpointPair :PJ1 ,
                                 :PJ3 ,
                                 :PJ9 ;
      :commitmentScore "3"^^xsd:int .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PJ11
:PJ11 rdf:type owl:NamedIndividual ,
               :CouplerSeatPJ ,
               :NonLockLikePJ ;
      :hasEndpoint :Bearing2 ,
                   :GearboxCover ;
      :hasInterfaceGeometry :Cylindrical ;
      :hasKinematicFunction :Fixed ;
      :hasRetentionMethod :PressFitFriction ;
      :sharesCouplingPartPair :PJ5 ;
      :sharesEndpointPair :PJ12 ,
                          :PJ3 ,
                          :PJ5 ;
      :commitmentScore "3"^^xsd:int .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PJ12
:PJ12 rdf:type owl:NamedIndividual ,
               :CouplerSeatPJ ,
               :NonLockLikePJ ;
      :hasEndpoint :Bearing4 ,
                   :GearboxCover ;
      :hasInterfaceGeometry :Cylindrical ;
      :hasKinematicFunction :Fixed ;
      :hasRetentionMethod :PressFitFriction ;
      :sharesCouplingPartPair :PJ8 ;
      :sharesEndpointPair :PJ11 ,
                          :PJ3 ,
                          :PJ8 ;
      :commitmentScore "3"^^xsd:int .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PJ2
:PJ2 rdf:type owl:NamedIndividual ,
              :MountedPowerElementPJ ,
              :NonLockLikePJ ;
     :hasEndpoint :Pinion ,
                  :Pump ;
     :hasInterfaceGeometry :Threaded ;
     :sharesEndpointPair :PJ1 ,
                         :PJ4 ,
                         :PJ5 ;
     :sharesPowerEndpointPair :PJ1 ,
                              :PJ4 ,
                              :PJ5 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PJ3
:PJ3 rdf:type owl:NamedIndividual ,
              :ClosurePJ ,
              :LockLikePJ ;
     :closureReachableViaSeatPair :PJ4 ,
                                  :PJ5 ,
                                  :PJ7 ,
                                  :PJ8 ;
     :defaultPrecedes :PJ10 ,
                      :PJ11 ,
                      :PJ12 ,
                      :PJ4 ,
                      :PJ5 ,
                      :PJ7 ,
                      :PJ8 ,
                      :PJ9 ;
     :hasEndpoint :GearboxCase ,
                  :GearboxCover ;
     :hasInterfaceGeometry :Planar ;
     :hasRetentionMethod :BoltedFastening ;
     :sharesEndpointPair :PJ1 ,
                         :PJ10 ,
                         :PJ11 ,
                         :PJ12 ,
                         :PJ9 ;
     :sharesSupportEndpointPair :PJ1 ,
                                :PJ10 ,
                                :PJ9 ;
     :commitmentScore "2"^^xsd:int .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PJ4
:PJ4 rdf:type owl:NamedIndividual ,
              :MotionRelevantPJ ,
              :NonLockLikePJ ;
     :defaultPrecedes :PJ2 ,
                      :PJ9 ;
     :hasEndpoint :Bearing1 ,
                  :Pinion ;
     :hasInterfaceGeometry :Cylindrical ;
     :hasKinematicFunction :Revolute ;
     :sharesCouplingPartPair :PJ9 ;
     :sharesEndpointPair :PJ2 ,
                         :PJ5 ,
                         :PJ9 ;
     :sharesPowerEndpointPair :PJ2 ,
                              :PJ5 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PJ5
:PJ5 rdf:type owl:NamedIndividual ,
              :MotionRelevantPJ ,
              :NonLockLikePJ ;
     :defaultPrecedes :PJ11 ,
                      :PJ2 ;
     :hasEndpoint :Bearing2 ,
                  :Pinion ;
     :hasInterfaceGeometry :Cylindrical ;
     :hasKinematicFunction :Revolute ;
     :sharesCouplingPartPair :PJ11 ;
     :sharesEndpointPair :PJ11 ,
                         :PJ2 ,
                         :PJ4 ;
     :sharesPowerEndpointPair :PJ2 ,
                              :PJ4 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PJ6
:PJ6 rdf:type owl:NamedIndividual ,
              :MountedPowerElementPJ ,
              :NonLockLikePJ ;
     :hasEndpoint :Gear ,
                  :InputShaft ;
     :hasInterfaceGeometry :Threaded ;
     :sharesEndpointPair :PJ7 ,
                         :PJ8 ;
     :sharesPowerEndpointPair :PJ7 ,
                              :PJ8 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PJ7
:PJ7 rdf:type owl:NamedIndividual ,
              :MotionRelevantPJ ,
              :NonLockLikePJ ;
     :defaultPrecedes :PJ10 ,
                      :PJ6 ;
     :hasEndpoint :Bearing3 ,
                  :InputShaft ;
     :hasInterfaceGeometry :Cylindrical ;
     :hasKinematicFunction :Revolute ;
     :sharesCouplingPartPair :PJ10 ;
     :sharesEndpointPair :PJ10 ,
                         :PJ6 ,
                         :PJ8 ;
     :sharesPowerEndpointPair :PJ6 ,
                              :PJ8 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PJ8
:PJ8 rdf:type owl:NamedIndividual ,
              :MotionRelevantPJ ,
              :NonLockLikePJ ;
     :defaultPrecedes :PJ12 ,
                      :PJ6 ;
     :hasEndpoint :Bearing4 ,
                  :InputShaft ;
     :hasInterfaceGeometry :Cylindrical ;
     :hasKinematicFunction :Revolute ;
     :sharesCouplingPartPair :PJ12 ;
     :sharesEndpointPair :PJ12 ,
                         :PJ6 ,
                         :PJ7 ;
     :sharesPowerEndpointPair :PJ6 ,
                              :PJ7 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PJ9
:PJ9 rdf:type owl:NamedIndividual ,
              :CouplerSeatPJ ,
              :NonLockLikePJ ;
     :hasEndpoint :Bearing1 ,
                  :GearboxCase ;
     :hasInterfaceGeometry :Cylindrical ;
     :hasKinematicFunction :Fixed ;
     :hasRetentionMethod :PressFitFriction ;
     :sharesCouplingPartPair :PJ4 ;
     :sharesEndpointPair :PJ1 ,
                         :PJ10 ,
                         :PJ3 ,
                         :PJ4 ;
     :sharesSupportEndpointPair :PJ1 ,
                                :PJ10 ,
                                :PJ3 ;
     :commitmentScore "3"^^xsd:int .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PinRetention
:PinRetention rdf:type owl:NamedIndividual ,
                       :RetentionMethod .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Pinion
:Pinion rdf:type owl:NamedIndividual ,
                 :PowerTransferPart .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Planar
:Planar rdf:type owl:NamedIndividual ,
                 :InterfaceGeometry .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/PressFitFriction
:PressFitFriction rdf:type owl:NamedIndividual ,
                           :RetentionMethod .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Prismatic
:Prismatic rdf:type owl:NamedIndividual ,
                    :KinematicFunction .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Pump
:Pump rdf:type owl:NamedIndividual ,
               :PowerTransferPart .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Revolute
:Revolute rdf:type owl:NamedIndividual ,
                   :KinematicFunction .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/SealingRetention
:SealingRetention rdf:type owl:NamedIndividual ,
                           :RetentionMethod .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/SnapRingRetention
:SnapRingRetention rdf:type owl:NamedIndividual ,
                            :RetentionMethod .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Spherical
:Spherical rdf:type owl:NamedIndividual ,
                    :KinematicFunction .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Threaded
:Threaded rdf:type owl:NamedIndividual ,
                   :InterfaceGeometry .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/ThreadedPair
:ThreadedPair rdf:type owl:NamedIndividual ,
                       :KinematicFunction .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/Transition
:Transition rdf:type owl:NamedIndividual ,
                     :FitRegime .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/bolts
:bolts rdf:type owl:NamedIndividual ,
                :Bolt .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/dmp_PJ3_PJ10
:dmp_PJ3_PJ10 rdf:type owl:NamedIndividual ,
                       :DefaultMacroPrecedence ;
              <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> :A1 ;
              :earlierJoint :PJ3 ;
              :laterJoint :PJ10 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/dmp_PJ3_PJ11
:dmp_PJ3_PJ11 rdf:type owl:NamedIndividual ,
                       :DefaultMacroPrecedence ;
              <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> :A1 ;
              :earlierJoint :PJ3 ;
              :laterJoint :PJ11 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/dmp_PJ3_PJ12
:dmp_PJ3_PJ12 rdf:type owl:NamedIndividual ,
                       :DefaultMacroPrecedence ;
              <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> :A1 ;
              :earlierJoint :PJ3 ;
              :laterJoint :PJ12 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/dmp_PJ3_PJ4
:dmp_PJ3_PJ4 rdf:type owl:NamedIndividual ,
                      :DefaultMacroPrecedence ;
             <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> :A2 ;
             :earlierJoint :PJ3 ;
             :laterJoint :PJ4 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/dmp_PJ3_PJ5
:dmp_PJ3_PJ5 rdf:type owl:NamedIndividual ,
                      :DefaultMacroPrecedence ;
             <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> :A2 ;
             :earlierJoint :PJ3 ;
             :laterJoint :PJ5 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/dmp_PJ3_PJ7
:dmp_PJ3_PJ7 rdf:type owl:NamedIndividual ,
                      :DefaultMacroPrecedence ;
             <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> :A2 ;
             :earlierJoint :PJ3 ;
             :laterJoint :PJ7 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/dmp_PJ3_PJ8
:dmp_PJ3_PJ8 rdf:type owl:NamedIndividual ,
                      :DefaultMacroPrecedence ;
             <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> :A2 ;
             :earlierJoint :PJ3 ;
             :laterJoint :PJ8 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/dmp_PJ3_PJ9
:dmp_PJ3_PJ9 rdf:type owl:NamedIndividual ,
                      :DefaultMacroPrecedence ;
             <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> :A1 ;
             :earlierJoint :PJ3 ;
             :laterJoint :PJ9 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/dmp_PJ4_PJ9
:dmp_PJ4_PJ9 rdf:type owl:NamedIndividual ,
                      :DefaultMacroPrecedence ;
             <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> :B1 ;
             :earlierJoint :PJ4 ;
             :laterJoint :PJ9 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/dmp_PJ5_PJ11
:dmp_PJ5_PJ11 rdf:type owl:NamedIndividual ,
                       :DefaultMacroPrecedence ;
              <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> :B1 ;
              :earlierJoint :PJ5 ;
              :laterJoint :PJ11 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/dmp_PJ7_PJ10
:dmp_PJ7_PJ10 rdf:type owl:NamedIndividual ,
                       :DefaultMacroPrecedence ;
              <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> :B1 ;
              :earlierJoint :PJ7 ;
              :laterJoint :PJ10 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/dmp_PJ7_PJ6
:dmp_PJ7_PJ6 rdf:type owl:NamedIndividual ,
                      :DefaultMacroPrecedence ;
             <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> :F1 ;
             :earlierJoint :PJ7 ;
             :laterJoint :PJ6 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/dmp_PJ8_PJ12
:dmp_PJ8_PJ12 rdf:type owl:NamedIndividual ,
                       :DefaultMacroPrecedence ;
              <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> :B1 ;
              :earlierJoint :PJ8 ;
              :laterJoint :PJ12 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/dmp_PJ8_PJ6
:dmp_PJ8_PJ6 rdf:type owl:NamedIndividual ,
                      :DefaultMacroPrecedence ;
             <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> :F1 ;
             :earlierJoint :PJ8 ;
             :laterJoint :PJ6 .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/oilSeal1
:oilSeal1 rdf:type owl:NamedIndividual ,
                   :Sealing .


###  http://www.semanticweb.org/ajaberi/fois2026/connection-pattern/oilSeal2
:oilSeal2 rdf:type owl:NamedIndividual ,
                   :Sealing .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Bolt
                :Key
                :Nut
                :Pin
                :Sealing
                :SnapRing
                :WasherShim
              )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :PJ1
                        :PJ10
                        :PJ11
                        :PJ12
                        :PJ2
                        :PJ3
                        :PJ4
                        :PJ5
                        :PJ6
                        :PJ7
                        :PJ8
                        :PJ9
                      )
] .


#################################################################
#    Rules
#################################################################

:pj rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:s rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:c rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:a rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:b rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:pjclose rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:pjseat rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:pjint rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:pj1 rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:pj2 rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:u rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:v rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:x rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "" ;
   rdfs:label "A1_Access_closure_default" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :ClosurePJ ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :a
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#classPredicate> :CouplerSeatPJ ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> :b
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> :sharesEndpointPair ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> :a ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> :b
                                                                           ] ;
                                                                 rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                            rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DifferentIndividualsAtom> ;
                                                                                        <http://www.w3.org/2003/11/swrl#argument1> :a ;
                                                                                        <http://www.w3.org/2003/11/swrl#argument2> :b
                                                                                      ] ;
                                                                            rdf:rest rdf:nil
                                                                          ]
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :defaultPrecedes ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :a ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> :b
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "" ;
   rdfs:label "E1_2_Motion_requirement_semantic_corridor" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :ClosurePJ ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :a
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#classPredicate> :MotionRelevantPJ ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> :b
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> :closureReachableViaSeatPair ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> :a ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> :b
                                                                           ] ;
                                                                 rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                            rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                                        <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasKinematicFunction ;
                                                                                        <http://www.w3.org/2003/11/swrl#argument1> :b ;
                                                                                        <http://www.w3.org/2003/11/swrl#argument2> :Cylindrical
                                                                                      ] ;
                                                                            rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                                       rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DifferentIndividualsAtom> ;
                                                                                                   <http://www.w3.org/2003/11/swrl#argument1> :a ;
                                                                                                   <http://www.w3.org/2003/11/swrl#argument2> :b
                                                                                                 ] ;
                                                                                       rdf:rest rdf:nil
                                                                                     ]
                                                                          ]
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
